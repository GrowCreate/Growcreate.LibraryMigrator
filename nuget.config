<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Pin restore to nuget.org so builds are reproducible for all contributors / CI.
       Prevents reliance on any machine-local private feed and satisfies central
       package management's single-source requirement. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
